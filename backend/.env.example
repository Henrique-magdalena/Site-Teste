# API Settings
PROJECT_NAME="Kinetic API"
DEBUG=True
API_V1_STR="/api/v1"

# Security
# Generate with: openssl rand -hex 32
SECRET_KEY="YOUR_SUPER_SECRET_KEY_CHANGEME"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=11520 # 8 days

# Database
# Supabase Transaction Pooler URI
# Example: postgresql+asyncpg://postgres:password@host:6543/postgres?ssl=require
DATABASE_URL="postgresql+asyncpg://postgres:[YOUR-PASSWORD]@[YOUR-HOST]:6543/postgres?ssl=require"

# First Superuser
FIRST_SUPERUSER="admin@kinetic.store"
FIRST_SUPERUSER_PASSWORD="admin_password_changeme"
